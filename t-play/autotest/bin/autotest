#!/bin/bash
# Play autotest games.
# Run autotest-client with low priority, picking an id automatically.
# Will run something like:
#
#	nice -n 18 bin/autotest-client `hostname`-N
#
# where N = 1, 2, 3, 4, ... for each instance of autotest you run (each instance
# must have its own id). 'nice -n 18' ensures go programs are run with low
# priority so cpu is available for interactive work.

die()  {  echo "$@"; exit 1;  }
bin=`dirname $0`

# id must be unique
find_id()
{
	echo -n "Looking for free id... "
	for i in `seq 1 16`; do
		id="$HOSTNAME-$i"
		if ! ps aux | grep -q "autotest-client $id\$"; then
			echo "Ok"
			return
		fi
	done
	die "no free id found"
}

find_id
cmd="nice -n 18 $bin/autotest-client $id"
echo "$cmd"
echo ""

exec $cmd
