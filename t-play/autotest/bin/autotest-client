#!/bin/bash
# This is autotest Go-testing framework client. It runs on client
# machines and spawns autotest-worker, which picks a random pairing
# among the ones defined in the rc file, and plays a single game.
bin=`dirname $0`

clientid="$1"; shift
if [ -z "$clientid" ]; then
	echo "Usage: $0 <clientid>" >&2
	echo "At any time, only a single client with the same clientid may run!" >&2
	echo "You can use e.g. clientid \`hostname\`-1, increment 1 for" >&2
	echo "further threads started on the host." >&2
	exit 1
fi
. $bin/autotest-lib

mkdir -p "c/$clientid"
log "started client ($clientid)"

# Move log to crashes directory
collect_crashlog()
{
	log="c/$clientid/game.log"
	if [ -f "$log" ]; then
		mkdir -p crashes
		i=0;  while [ -f "crashes/game.log.$i" ]; do i=$[$i+1]; done
		mv  "$log" "crashes/game.log.$i"
		echo "Wrote crashes/game.log.$i"
	fi
}

# Sync workers at the end of each round.
# Syncing workers involves 2 locks:
# - One at the end of the round to ensure all games are finished (this one)
# - Another before next round starts to ensure all workers have been notified
#   and use the same pairing (see autotest-worker).
sync_workers()
{
	[ "$sync_workers" = "y" ] || return 0
	echo ""

	# Round finished, wait for other workers to finish their game.
	rm -f c/$clientid/round_ready
	touch "c/$clientid/round_done"
	msg='Sync workers: Waiting for game #$i to finish ...'
	wait_for_other_workers "round_done" .5 "$msg"
	echo "Sync workers: All games for this round finished."
}

# Get sync_workers variable from rc
eval "`grep sync_workers rc`"

while true; do
	mkdir -p "c/$clientid"
	date +%s >"c/$clientid/beacon"

	if ! $bin/autotest-worker "$clientid"; then
		collect_crashlog
		echo "*** WORKER FAILED ***"
		log "worker failed with error code $?"
		echo ""
		sleep 1
	fi

	sync_workers
done
