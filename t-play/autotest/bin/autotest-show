#!/bin/bash
# This is autotest display tool, showing gathered information in
# a hopefully meaningful way.
#
# Usage: ./autotest-show [options] [MASK]
# Options:
#    -e, --elo     display winrates in terms of Elo points.
#    -f, --force   force regeneration of all pairings summary files
#
# If players disagree on winrate a sign is displayed (scoring bug usually):
#    S GAMES WR B    WR W    S.D.    PAIRING
#    / 420   0.769   0.769   0.021   9-h2-2-katago-pachi_1290
#    / 472   0.775 ! 0.773   0.019   9-h2-2-katago-pachi_1290_buggy
#                 ^^^
# find_scoring_bugs can be used to find offending games.

bin=`dirname $0`

# Make printf work for floats
export LC_NUMERIC="en_US.UTF-8"

do_elo=

while [ ${1:0:1} = "-" ]; do
	if [ "$1" = "-e" ] || [ "$1" = "--elo" ]; then
		do_elo=1
		shift; continue
	fi

	if [ "$1" = "-f" ] || [ "$1" = "--force " ]; then
		rm -f r/*.summary.dat r/*.html
		shift; continue
	fi
done

mask="$1"
[ -n "$mask" ] || mask=".*"
. $bin/autotest-lib

if [ ! -d "r" ]; then
	echo "Did you run autotest-gather?" >&2
	exit 1
fi

# Load rc quickly:
player() { :; }
pknown=" "
pairing() { pknown="$pknown$(pairid "$@") "; }
. ./rc

color_stale="\033[33m"
color_bad="\033[31m"
color_fresh="\033[1m"
color_stop="\033[0m"

pairing_status() {
	# See README for explanation of flags.
	error=0;
	if [ -s "r/$pairing.error" ] && [ "$(cat "r/$pairing.error")" -gt 0 ]; then
		error=1;
	fi
	known=1; [ "${pknown#* $pairing *}" != "$pknown" ] || known=0
	active=1; ([ -s "r/$pairing.beacon" ] && [ "$(cat "r/$pairing.beacon")" -ge "$(($(date +%s) - 60*60*2))" ]) || active=0
	case $error$known$active in
		001) status="${color_stale}?";;
		000) status="${color_stale}/";;
		011) status="${color_fresh}.";;
		010) status="${color_fresh}${color_bad}!";;
		1*0) status="${color_bad}x";;
		1*1) status="${color_fresh}${color_bad}X";;
	esac
}

#[ -n "$do_elo" ] && echo "Formula: 100 ELO = 64% winning prob,  1 stone ~= 150 ELO (orig)"
#elo_rank=157
#prob2elo() {
#	echo "400*l(10*$1/(1-$1))/l(10)" | bc -l
#}

[ -n "$do_elo" ] && echo "Formula: 100 ELO = 1 stone = 71.3% winning prob  (EGF)"
elo_rank=100
prob2elo() {
	echo "110 * l($1 / (1-$1))" | bc -l
}

elo_stats() {
	ref=0.5
	refelo=$(prob2elo $ref); wrelo=$(prob2elo $winrate);
	wrelo_d=$(prob2elo "($winrate-$sd)"); wrelo_u=$(prob2elo "($winrate+$sd)")
	delo=$((${wrelo%.*}-${refelo%.*})); delo_u=$((${wrelo_u%.*}-${refelo%.*})); delo_d=$((${wrelo_d%.*}-${refelo%.*}))
	drank=`echo "scale=1; $delo / $elo_rank" | bc`
	stats=`printf "%-7s %-+5i  %-+5i  %-+5i    %-+8.1f" "$games" "$delo_d" "$delo" "$delo_u" "$drank"`
}


if [ -n "$do_elo" ]; then
	printf "\nS GAMES  [-SD    ELO    +SD]     RANK     PAIRING\n"
else
	printf "S GAMES WR B    WR W    S.D.    PAIRING\n"
fi

list_known_pairings()
{
	(  echo "$pknown" | tr ' ' '\n'						# Pairings from rc file
	   ls r/*.dat | grep -vF '.summary.' | sed 's|^r/||; s|\.dat$||'	# Pairings results
	) | sort -u
}

for pairing in `list_known_pairings | grep "$mask"`; do
	# Regenerate pairing .summary.dat if needed
	if [ "r/$pairing.dat" -nt "r/$pairing.summary.dat" ]; then
		rm -f "r/$pairing.summary.dat" "r/$pairing.html"
		$twogtp_path -analyze "r/$pairing.dat"
	fi

	pairing_status "$pairing"	# Sets status

	if ! [ -s "r/$pairing.summary.dat" ]; then
		printf "$status 0     -       -       -       $pairing$color_stop\n"
		continue
	fi

	cat "r/$pairing.summary.dat" | cut -f 1,7,8,12 | tail -n +2 |
	while read games winrate sd winrate2; do
		if [ -n "$do_elo" ]; then
			elo_stats
		else
			agree=" "
			# Players disagree on winrate ? (scoring bug usually)
			[ "$winrate" != "$winrate2" ] && agree="!"

			stats=`printf "%-5s %-5s $agree %-7s %-7s" "$games" "$winrate" "$winrate2" "$sd"`
		fi
		printf "$status $stats $pairing$color_stop\n"
		break
	done
done

echo
echo "crashes: " `ls crashes/* 2>/dev/null | wc -l`
